{
  "name": "nogatekeeping",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node scripts/generate-sitemap.mjs && node scripts/generate-public-data.mjs && vite build && node scripts/prerender-seo.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "data:public": "node scripts/generate-public-data.mjs",
    "prerender:seo": "node scripts/prerender-seo.mjs",
    "qa:routes": "node scripts/route-runtime-qa.mjs",
    "qa:routes:browser": "playwright test tests/route-runtime.spec.ts",
    "qa:seo": "npm run build && playwright test tests/seo-metadata.spec.ts",
    "audit:seo": "npm run build && node scripts/audit-seo.mjs",
    "audit:seo:ci": "npm run build && node scripts/audit-seo.mjs --fail-on-warn"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.49.0",
    "@mui/material": "^9.1.2",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "jszip": "^3.10.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.542.0",
    "multer": "^2.1.1",
    "opentype.js": "^1.3.4",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "18.3.1",
    "react-router-dom": "^6.26.2",
    "sharp": "^0.34.5",
    "tinycolor2": "^1.6.0",
    "ttf2eot": "^3.1.0",
    "ttf2woff": "^3.0.0",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/html2canvas": "^0.5.35",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.6"
  },
  "overrides": {
    "react-is": "18.3.1"
  }
}
